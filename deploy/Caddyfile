# HTTPS reverse proxy for the MOTIS API.
# Replace the domain with yours (e.g. a free DuckDNS subdomain).
# Caddy fetches and renews Let's Encrypt certificates automatically.

howfarhowfast.duckdns.org {
	# CORS for the web app (set only if MOTIS didn't already)
	header ?Access-Control-Allow-Origin "*"

	# Only expose the API paths the app needs.
	@api path /api/v6/one-to-all* /api/v1/geocode* /api/v1/reverse-geocode*
	handle @api {
		reverse_proxy 127.0.0.1:8080
	}
	handle {
		respond "howfarhowfast routing API" 200
	}
}
